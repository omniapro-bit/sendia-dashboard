# Sendia Dashboard - Production Environment Variables
# Copy this file to .env.prod and fill in the values before deployment

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Configuration
NEXT_PUBLIC_API_BASE=https://api.your-domain.com

# Node environment (do not change)
NODE_ENV=production
