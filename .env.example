# Sendia Dashboard — Environment Variables
# Copy this file to .env.local (development) or .env.prod (production) and fill in every value.
# Variables prefixed with NEXT_PUBLIC_ are embedded into the client-side bundle at build time
# and are therefore visible to end users — never put secrets in these vars.

# ---------------------------------------------------------------------------
# Supabase (client-side)
# ---------------------------------------------------------------------------

# Public URL of your Supabase project.
# Found in Supabase Dashboard → Project Settings → API → Project URL.
# Required.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key.
# Found in Supabase Dashboard → Project Settings → API → Project API keys → anon/public.
# This key is safe to expose in the browser; Row Level Security enforces data access.
# Required.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Base URL of the Sendia API backend (no trailing slash).
# The dashboard appends /api/client/... to this value for all authenticated requests.
# Example for local development: http://localhost:3500
# Example for production:        https://api.getsendia.com
# Required.
NEXT_PUBLIC_API_BASE=https://api.getsendia.com

# ---------------------------------------------------------------------------
# Node environment
# ---------------------------------------------------------------------------

# Runtime environment passed to Next.js.
# Accepted values: development | production
# Do not change this in the production deployment config.
NODE_ENV=production
